msgstr "Nima qilish kerak"

msgid "Select all rows"
msgstr "Barchasini belgilash"

msgid "Run"
msgstr "Bajarish"

msgid "More actions"
msgstr "Boshqa amallar"

msgid "Filters"
msgstr "Saralash"

msgid "Apply Filters"
msgstr "Saralash"

msgid "Clear all filters"
msgstr "Saralashni tozalash"

msgid "Clear selection"
msgstr "Belgilashni bekor qilish"

msgid "Click here to select the objects across all pages"
msgstr "Barcha sahifalardagi yozuvlarni belgilash uchun shu yerni bosing"

msgid "No records found."
msgstr "Hech nima topilmadi."

msgid "Show all"
msgstr "Hammasini ko'rsatish"

msgid "All applications"
msgstr "Barcha bo'limlar"

msgid "General"
msgstr "Umumiy"

msgid "Toggle sorting"
msgstr "Tartiblash"

msgid "Type to search"
msgstr "Qidirish uchun yozing"

msgid "Dark"
msgstr "Qorong'i"

msgid "Light"
msgstr "Yorug'"

msgid "System"
msgstr "Tizimdagidek"

msgid "Menu"
msgstr "Menyu"

msgid "Please correct the error below."
msgstr "Quyidagi xatoni to'g'rilang."

msgid "Please correct the errors below."
msgstr "Quyidagi xatolarni to'g'rilang."

msgid "Log in again"
msgstr "Qayta kirish"

msgid "You have been successfully logged out from the administration"
msgstr "Siz tizimdan chiqdingiz"

msgid "Thanks for spending some quality time with the web site today."
msgstr "Ishingizga omad!"

msgid "You don’t have permission to view or edit anything."
msgstr "Sizda hech narsani ko'rish yoki tahrirlash uchun ruxsat yo'q."

msgid "Please enter your old password, for security’s sake, and then enter your new password twice so we can verify you typed it in correctly."
msgstr "Xavfsizlik uchun avval eski parolingizni kiriting, so'ng yangi parolni ikki marta yozing."
