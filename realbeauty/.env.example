# Real Beauty CRM — environment nusxasi. `.env` nomi bilan ko'chiring:
#   cp .env.example .env
# So'ng har bir qiymatni to'ldiring. .env hech qachon git'ga qo'shilmaydi.

# --- Django ---
# Kuchli kalit yarating:  python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
DJANGO_SETTINGS_MODULE=core.settings.prod
DEBUG=False
# Serverdagi domen(lar), vergul bilan. Masalan: crm.realbeauty.uz
ALLOWED_HOSTS=

# --- Postgres ---
POSTGRES_DB=realbeauty
POSTGRES_USER=realbeauty
# Kuchli parol:  python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Telegram bot ---
# @BotFather -> /newbot yoki /token. DIQQAT: token sirdir — chatga, git'ga,
# skrinshotga tushsa, @BotFather'da /revoke qilib yangisini oling.
BOT_TOKEN=
# Bot username @ belgisisiz (referal havolalar uchun)
BOT_USERNAME=

# --- Mobil ilova (Flutter) ---
# Ilova shu kalitni X-Api-Key header'da yuboradi (/api/app-users/register/,
# /api/auth/phone/request-code/, /api/auth/phone/verify-code/).
# Kuchli kalit yarating:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# Ilova tomonidagi (real_beauty_ai) qiymat bilan bir xil bo'lishi shart.
APP_API_KEY=

# --- Eskiz.uz (ilovadagi telefon orqali kirish uchun SMS) ---
# https://eskiz.uz da ro'yxatdan o'ting, email/parolni shu yerga yozing.
# Diqqat: haqiqiy raqamlarga SMS yuborish uchun "from" nickname/shablon
# Eskiz tomonidan tasdiqlanishi kerak — tasdiqlanmaguncha faqat ularning
# test raqamiga (998900000000) yuboriladi.
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_SMS_FROM=4546

# --- Firebase Admin (OTP tasdiqlangach custom token yaratish uchun) ---
# Firebase Console → Project settings → Service accounts → Generate new
# private key. Yuklab olingan JSON faylni serverga qo'yib, shu yerga to'liq
# yo'lini yozing (masalan: /app/secrets/firebase-service-account.json).
# DIQQAT: bu fayl sir — git'ga hech qachon qo'shilmasin.
FIREBASE_SERVICE_ACCOUNT_JSON=
