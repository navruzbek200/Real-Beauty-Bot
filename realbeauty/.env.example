# Real Beauty CRM — environment nusxasi. `.env` nomi bilan ko'chiring:
#   cp .env.example .env
# So'ng har bir qiymatni to'ldiring. .env hech qachon git'ga qo'shilmaydi.

# --- Django ---
# Kuchli kalit yarating:  python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
DJANGO_SETTINGS_MODULE=core.settings.prod
DEBUG=False
# Serverdagi domen(lar), vergul bilan. Masalan: crm.realbeauty.uz
ALLOWED_HOSTS=

# --- Postgres ---
POSTGRES_DB=realbeauty
POSTGRES_USER=realbeauty
# Kuchli parol:  python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Telegram bot ---
# @BotFather -> /newbot yoki /token. DIQQAT: token sirdir — chatga, git'ga,
# skrinshotga tushsa, @BotFather'da /revoke qilib yangisini oling.
BOT_TOKEN=
# Bot username @ belgisisiz (referal havolalar uchun)
BOT_USERNAME=
